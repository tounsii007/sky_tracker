# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.dart]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{yaml,yml,json,toml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{gradle,kts}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
