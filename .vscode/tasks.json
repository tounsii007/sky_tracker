{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: pub get",
      "type": "shell",
      "command": "flutter pub get",
      "problemMatcher": []
    },
    {
      "label": "Flutter: analyze",
      "type": "shell",
      "command": "flutter analyze",
      "problemMatcher": ["$dart-build_runner"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Flutter: test (unit)",
      "type": "shell",
      "command": "flutter test test/unit/ --reporter expanded",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Flutter: test (all)",
      "type": "shell",
      "command": "flutter test --reporter expanded",
      "group": "test"
    },
    {
      "label": "Flutter: format",
      "type": "shell",
      "command": "dart format --line-length=100 lib/ test/"
    },
    {
      "label": "Codegen: build_runner build (delete conflicting)",
      "type": "shell",
      "command": "dart run build_runner build --delete-conflicting-outputs"
    },
    {
      "label": "Codegen: build_runner watch",
      "type": "shell",
      "command": "dart run build_runner watch --delete-conflicting-outputs",
      "isBackground": true
    }
  ]
}
