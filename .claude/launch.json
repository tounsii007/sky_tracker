{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flutter-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port", "8888"],
      "port": 8888
    },
    {
      "name": "cors-proxy",
      "runtimeExecutable": "dart",
      "runtimeArgs": ["run", "proxy/bin/proxy_server.dart"],
      "port": 8080
    },
    {
      "name": "nextjs-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "C:/projects/airwatch-web"],
      "port": 3000
    }
  ]
}
